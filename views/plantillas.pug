extends layout

block content
    .container.mt-4
        .vista-header
            h2.mb-0 Mis Plantillas  

        if error
            .alert.alert-danger
                i.fas.fa-circle-exclamation.me-2
                | #{error}

        else if plantillas && plantillas.length > 0

            each p in plantillas

                .card.mb-3

                    .card-body.d-flex.justify-content-between.align-items-center

                        div
                            h6.mb-1 #{p.nombrePlantilla}
                            small.text-muted
                                != p.contenido

                        form(
                            action=`/plantillas/${p.idPlantilla}?_method=DELETE`
                            method="POST"
                        )

                            button.btn.btn-outline-danger.btn-sm
                                i.fas.fa-trash

        else

            p.text-muted
                | No tenés plantillas guardadas aún.
