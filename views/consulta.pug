extends layout 

block content
    .vista-header
        h2.mb-0 Consulta Médica

    if isVisible
        p(style="display: block; color: green; font-size: 24px; font-weight: bold; text-align: center;") Consulta guardada!
    if error
        p(style="display: block; color: red; font-size: 24px; font-weight: bold; text-align: center;") #{errorMensaje}   

    .container-fluid.mt-4
        .row
            .col-md-9
                form(action=`/consulta/${idConsulta}/finalizar` method="POST" id="formFinalizar")
                    .card.mb-4
                        .card-header
                            h5.mb-0
                                i.fas.fa-notes-medical.me-2
                                | Evolución

                        .card-body

                            button.btn.btn-outline-secondary.btn-sm.mb-3( type="button" data-bs-toggle="modal" data-bs-target="#modalPlantillas")
                                i.fas.fa-file-alt.me-1
                                | Cargar plantilla

                            input(type="hidden" id="evolucionExistente" value=consulta.evolucion || "")

                            div#editor(style="height: 250px;")

                            input(type="hidden" id="editorContent" name="evolucion")

                .container
                    .row
                        .col-md-6
                            button.btn.btn-primary.btn-action(data-bs-toggle="modal" data-bs-target="#modalDiagnostico") + Diagnóstico

                            if consulta.diagnosticos && consulta.diagnosticos.length > 0
                                h3.mt-4 Diagnósticos
                                each d in consulta.diagnosticos
                                    .card.mb-3
                                        .card-body.d-flex.justify-content-between.align-items-center
                                            div
                                                p.mb-1 #{d.detalleDiagnostico}
                                                small.text-muted #{d.tipoDiagnostico}
                                            form(action=`/diagnostico/${d.idDiagnostico}?_method=DELETE` method="POST")
                                                button.btn.btn-outline-danger.btn-sm
                                                    i.fas.fa-trash

                        .col-md-6
                            button.btn.btn-primary.btn-action(data-bs-toggle="modal" data-bs-target="#modalMedicamento") + Medicamento

                            if consulta.medicamentos && consulta.medicamentos.length > 0
                                h3.mt-4 Medicamentos
                                each m in consulta.medicamentos
                                    .card.mb-3
                                        .card-body.d-flex.justify-content-between.align-items-center
                                            div
                                                p.mb-1 #{m.nombreMedicamento}
                                            form(action=`/medicamento/${m.idMedicamento}?_method=DELETE` method="POST")
                                                button.btn.btn-outline-danger.btn-sm
                                                    i.fas.fa-trash

                    .row.mt-3
                        .col-md-6
                            button.btn.btn-primary.btn-action(data-bs-toggle="modal" data-bs-target="#modalAntecedente") + Antecedente

                            if consulta.antecedentes && consulta.antecedentes.length > 0
                                h3.mt-4 Antecedentes
                                each a in consulta.antecedentes
                                    .card.mb-3
                                        .card-body.d-flex.justify-content-between.align-items-center
                                            div
                                                p.mb-1 #{a.descripcionAntecedente}
                                                small.text-muted Desde: #{a.fechaDesdeAntecedente} - Hasta: #{a.fechaHastaAntecedente}
                                            form(action=`/antecedentes/${a.idAntecedente}?_method=DELETE` method="POST")
                                                button.btn.btn-outline-danger.btn-sm
                                                    i.fas.fa-trash

                        .col-md-6
                            button.btn.btn-primary.btn-action(data-bs-toggle="modal" data-bs-target="#modalHabito") + Habito

                            if consulta.habitos && consulta.habitos.length > 0
                                h3.mt-4 Habitos
                                each h in consulta.habitos
                                    .card.mb-3
                                        .card-body.d-flex.justify-content-between.align-items-center
                                            div
                                                p.mb-1 #{h.descripcionHabito}
                                                small.text-muted Desde: #{h.fechaDesdeHabito} - Hasta: #{h.fechaHastaHabito}
                                            form(action=`/habito/${h.idHabito}?_method=DELETE` method="POST")
                                                button.btn.btn-outline-danger.btn-sm
                                                    i.fas.fa-trash

                    .row.mt-3
                        .col-md-12
                            button.btn.btn-primary.mb-2(data-bs-toggle="modal" data-bs-target="#modalAlergia") + Alergia

                            if consulta.alergias && consulta.alergias.length > 0
                                h3.mt-3 Alergias
                                each a in consulta.alergias
                                    .card.mb-2
                                        .card-body.d-flex.justify-content-between.align-items-center
                                            div
                                                p.mb-1 #{a.alergia.nombreAlergia}
                                                small.text-muted Importancia: #{a.importancia.gradoImportancia}
                                                br
                                                small.text-muted Desde: #{a.fechaDesdeAlergia} - Hasta: #{a.fechaHastaAlergia}
                                            form(action=`/consultaAlergia/${a.idConsultaAlergia}?_method=DELETE` method="POST")
                                                button.btn.btn-outline-danger.btn-sm
                                                    i.fas.fa-trash

                .d-flex.justify-content-end.mt-4.mb-5
                    button.btn.btn-primary.btn-lg(type="submit" form="formFinalizar")
                        i.fas.fa-check.me-2
                        | Finalizar Consulta

            //- COLUMNA DERECHA - Historial
            .col-md-3
                .card.shadow-sm(style="position: sticky; top: 20px; max-height: 90vh; overflow-y: auto;")
                    .card-header
                        h6.mb-0
                            i.fas.fa-history.me-2
                            | Historial del Paciente

                    .card-body.p-2
                        if historial && historial.length > 0
                            each h in historial
                                .accordion.mb-2(id=`acc_${h.idConsulta}`)
                                    .accordion-item
                                        h2.accordion-header
                                            button.accordion-button.collapsed(
                                                type="button"
                                                data-bs-toggle="collapse"
                                                data-bs-target=`#col_${h.idConsulta}`
                                            )
                                                small
                                                    - const fecha = new Date(h.fechaAtencion).toLocaleDateString("es-ES")
                                                    | 📅 #{fecha}
                                        .accordion-collapse.collapse(id=`col_${h.idConsulta}`)
                                            .accordion-body.p-2
                                                
                                                small
                                                    strong Motivo: 
                                                    | #{h.turno ? h.turno.motivo : 'No asignado'}

                                                hr.my-1

                                            
                                                small
                                                    strong Diagnósticos:
                                                if h.diagnosticos && h.diagnosticos.length > 0
                                                    each d in h.diagnosticos
                                                        .ms-2
                                                            small
                                                                span.badge.bg-secondary.me-1 #{d.tipoDiagnostico}
                                                                | #{d.detalleDiagnostico}
                                                else
                                                    small.text-muted  No registrado

                                                //- EL RESTO SOLO SI ES SU CONSULTA
                                                if h.turno && h.turno.agenda && h.turno.agenda.medicoespecialidad && h.turno.agenda.medicoespecialidad.idMedicoFK === usuario.idMedicoFK

                                                    hr.my-1
                                                    small
                                                        strong Evolución:
                                                    if h.evolucion
                                                        .ms-2.mt-1!= h.evolucion
                                                    else
                                                        small.text-muted  No registrada

                                                    hr.my-1
                                                    small
                                                        strong Medicamentos:
                                                    if h.medicamentos && h.medicamentos.length > 0
                                                        each m in h.medicamentos
                                                            .ms-2
                                                                small #{m.nombreMedicamento}
                                                    else
                                                        small.text-muted  No registrado

                                                    hr.my-1
                                                    small
                                                        strong Antecedentes:
                                                    if h.antecedentes && h.antecedentes.length > 0
                                                        each a in h.antecedentes
                                                            .ms-2
                                                                small #{a.descripcionAntecedente}
                                                                br
                                                                small.text-muted Desde: #{a.fechaDesdeAntecedente} - Hasta: #{a.fechaHastaAntecedente}
                                                    else
                                                        small.text-muted  No registrado

                                                    hr.my-1
                                                    small
                                                        strong Hábitos:
                                                    if h.habitos && h.habitos.length > 0
                                                        each hab in h.habitos
                                                            .ms-2
                                                                small #{hab.descripcionHabito}
                                                                br
                                                                small.text-muted Desde: #{hab.fechaDesdeHabito} - Hasta: #{hab.fechaHastaHabito}
                                                    else
                                                        small.text-muted  No registrado

                                                    hr.my-1
                                                    small
                                                        strong Alergias:
                                                    if h.alergias && h.alergias.length > 0
                                                        each a in h.alergias
                                                            .ms-2
                                                                small #{a.alergia.nombreAlergia}
                                                                br
                                                                small.text-muted Importancia: #{a.importancia.gradoImportancia} | Desde: #{a.fechaDesdeAlergia} - Hasta: #{a.fechaHastaAlergia}
                                                    else
                                                        small.text-muted  No registrado

                                                else
                                                    hr.my-1
                                                    p.text-muted.text-center
                                                        i.fas.fa-lock.me-1
                                                        small Los demás datos son privados del médico tratante.
                        else
                            p.text-muted.text-center.mt-3
                                small No hay consultas anteriores


    .modal.fade#modalDiagnostico(tabindex="-1")
        .modal-dialog
            .modal-content
                .modal-header
                    h5.modal-title Nuevo Diagnóstico
                    button.btn-close(type="button" data-bs-dismiss="modal")

                form(action=`/diagnostico/${idConsulta}` method="POST")
                    .modal-body
                        textarea.form-control(name="diagnostico" required)

                        select.form-select.mt-2(name="tipoDiagnostico")
                            option(value="preliminar") Preliminar
                            option(value="confirmado") Confirmado

                    .modal-footer
                        button.btn.btn-secondary(type="button" data-bs-dismiss="modal") Cancelar
                        button.btn.btn-primary.btn-action(type="submit") Guardar

    .modal.fade#modalMedicamento(tabindex="-1")
        .modal-dialog
            .modal-content
                .modal-header
                    h5.modal-title Nuevo Medicamento
                    button.btn-close(type="button" data-bs-dismiss="modal")

                form(action=`/medicamento/${idConsulta}` method="POST")
                    .modal-body
                        textarea.form-control(name="medicamento" placeholder="Ingrese medicamento" required)

                    .modal-footer
                        button.btn.btn-secondary(type="button" data-bs-dismiss="modal") Cancelar
                        button.btn.btn-primary.btn-action(type="submit") Guardar

    .modal.fade#modalAntecedente(tabindex="-1")
        .modal-dialog
            .modal-content
                .modal-header
                    h5.modal-title Nuevo Antecedente
                    button.btn-close(type="button" data-bs-dismiss="modal")

                form(action=`/antecedentes/${idConsulta}` method="POST")
                    .modal-body
                        textarea.form-control(name="descripcionAntecedente" placeholder="Ingrese antecedente" required)

                        input.form-control.mt-2(type="date" name="fechaDesdeAntecedente")
                        input.form-control.mt-2(type="date" name="fechaHastaAntecedente")

                    .modal-footer
                        button.btn.btn-secondary(type="button" data-bs-dismiss="modal") Cancelar
                        button.btn.btn-primary.btn-action(type="submit") Guardar
    
    .modal.fade#modalHabito(tabindex="-1")
        .modal-dialog
            .modal-content
                .modal-header
                    h5.modal-title Nuevo Habito
                    button.btn-close(type="button" data-bs-dismiss="modal")

                form(action=`/habito/${idConsulta}` method="POST")
                    .modal-body
                        textarea.form-control(name="descripcionHabito" placeholder="Ingrese habito" required)

                        input.form-control.mt-2(type="date" name="fechaDesdeHabito")
                        input.form-control.mt-2(type="date" name="fechaHastaHabito")

                    .modal-footer
                        button.btn.btn-secondary(type="button" data-bs-dismiss="modal") Cancelar
                        button.btn.btn-primary.btn-action(type="submit") Guardar
                
    .modal.fade#modalAlergia(tabindex="-1")
        .modal-dialog
            .modal-content
                .modal-header
                    h5.modal-title Nueva Alergia
                    button.btn-close(type="button" data-bs-dismiss="modal")

                form(action=`/consultaAlergia/${idConsulta}` method="POST")
                    .modal-body
                        
                        label.form-label Alergia
                        select.form-select(name="idAlergiaFK" required)
                            option(value="") Seleccione una alergia
                            each a in alergias
                                option(value=a.idAlergia) #{a.nombreAlergia}

                        label.form-label.mt-2 Importancia
                        select.form-select(name="idImportanciaFK" required)
                            option(value="") Seleccione importancia
                            each i in importancias
                                option(value=i.idImportancia) #{i.gradoImportancia}
                        
                        label.form-label.mt-2 Desde
                        input.form-control(type="date" name="fechaDesdeAlergia" required)

                        label.form-label.mt-2 Hasta
                        input.form-control(type="date" name="fechaHastaAlergia")

                    .modal-footer
                        button.btn.btn-secondary(type="button" data-bs-dismiss="modal") Cancelar
                        button.btn.btn-primary.btn-action(type="submit") Guardar

    .modal.fade#modalPlantillas(tabindex="-1")
        .modal-dialog
            .modal-content
                .modal-header
                    h5.modal-title Seleccionar Plantilla
                    button.btn-close(type="button" data-bs-dismiss="modal")
                .modal-body
                    select.form-select#selectPlantilla
                        option(value="") Cargando...
                .modal-footer
                    button.btn.btn-secondary(type="button" data-bs-dismiss="modal") Cancelar
                    button.btn.btn-primary.btn-action(onclick="cargarPlantilla()") Cargar
block scripts
    script(src="https://cdn.jsdelivr.net/npm/quill@2.0.2/dist/quill.js")
    script(src="/js/consulta.js")

            



            

           
        

