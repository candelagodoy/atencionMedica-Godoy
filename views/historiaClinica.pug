extends layout

block content
    .vista-header
            h2.mb-0 Historia Clínica
    .container.mt-4
        each consulta, index in consultas

            .card.mb-4.shadow-sm

                .card-header

                    .d-flex.justify-content-between.align-items-center
                        div
                            h5.mb-0 📅 #{consulta.fechaAtencion.toISOString().split('T')[0]}
                        
                        //- Botón editar la ultima consulta y solo si es su medico
                        if index === 0 && consulta.turno.agenda.medicoespecialidad.idMedicoFK === usuario.idMedicoFK
                            a.btn.btn-warning.btn-sm(href=`/consulta/${consulta.idConsulta}`)
                                i.fas.fa-edit.me-1
                                | Editar

                .card-body
                    ul.list-group.list-group-flush

                        strong.detalle-titulo Motivo de Consulta: 
                            | #{consulta.turno ? consulta.turno.motivo : 'No aregistrado'}
                        br


                        strong.detalle-titulo Médico: 
                            | #{consulta.turno && consulta.turno.agenda && consulta.turno.agenda.medicoespecialidad && consulta.turno.agenda.medicoespecialidad.medico && consulta.turno.agenda.medicoespecialidad.medico.persona ? consulta.turno.agenda.medicoespecialidad.medico.persona.nombre + ' ' + consulta.turno.agenda.medicoespecialidad.medico.persona.apellido : 'No registrado'}
                        br

                        strong.detalle-titulo Diagnósticos: 
                            if consulta.diagnosticos && consulta.diagnosticos.length > 0
                                each d in consulta.diagnosticos
                                    .ms-2.mt-1
                                        span.badge.bg-secondary.me-2 #{d.tipoDiagnostico}
                                        | #{d.detalleDiagnostico}
                            else
                                span.text-muted  No asignado
                        br
                        //- A PARTIR DE ACÁ SOLO EL MÉDICO QUE REGISTRÓ LA CONSULTA
                        if consulta.turno.agenda.medicoespecialidad.idMedicoFK === usuario.idMedicoFK

                            strong.detalle-titulo Evolucion: 
                                if consulta.evolucion
                                    div.mt-2!= consulta.evolucion
                                else
                                    span.text-muted  No registrado
                            br

                            strong.detalle-titulo Antecedentes: 
                                if consulta.antecedentes && consulta.antecedentes.length > 0
                                    each a in consulta.antecedentes
                                        .ms-2.mt-1
                                            | #{a.descripcionAntecedente}
                                            small.text-muted.ms-2 Desde: #{a.fechaDesdeAntecedente} - Hasta: #{a.fechaHastaAntecedente}
                                else
                                    span.text-muted  No registrado
                            br

                            strong.detalle-titulo Medicamentos: 
                                if consulta.medicamentos && consulta.medicamentos.length > 0
                                    each m in consulta.medicamentos
                                        .ms-2.mt-1
                                            | #{m.nombreMedicamento}
                                else
                                    span.text-muted  No registrado
                            br

                            strong.detalle-titulo Hábitos: 
                                if consulta.habitos && consulta.habitos.length > 0
                                    each h in consulta.habitos
                                        .ms-2.mt-1
                                            | #{h.descripcionHabito}
                                            small.text-muted.ms-2 Desde: #{h.fechaDesdeHabito} - Hasta: #{h.fechaHastaHabito}
                                else
                                    span.text-muted  No registrado
                            br 

                            strong.detalle-titulo Alergias: 
                                if consulta.alergias && consulta.alergias.length > 0
                                    each a in consulta.alergias
                                        .ms-2.mt-1
                                            | #{a.alergia.nombreAlergia}
                                            small.text-muted.ms-2 Importancia: #{a.importancia.gradoImportancia} | Desde: #{a.fechaDesdeAlergia} - Hasta: #{a.fechaHastaAlergia}
                                else
                                    span.text-muted  No registrado

                        else
                            //- MENSAJE PARA CONSULTAS DE OTROS MÉDICOS
                            li.list-group-item.text-muted
                                i.fas.fa-lock.me-2
                                | Los demás datos de esta consulta son privados del médico tratante.
    if error
        .alert.alert-danger
            i.fas.fa-circle-exclamation.me-2
            | #{error}  
