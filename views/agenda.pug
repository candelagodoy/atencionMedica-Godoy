html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport", content="width=device-width, initial-scale=1.0")
        title Document
        link(rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css")
        script(src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js")
    body(style="background-image: url('../imagenes/fondoMedico.jpeg');")
        header.text-white.py-4(style="background-color: #84d5d5; color: white;") 
            h1.text-center Atención Médica  
            p.text-center Agenda
        container.d-flex.justify-content-center.align-items-center.mt-4
            .text-center.p-4.border.rounded.shadow-lg(style="background-color: #e4e4e4; color: #333;")
                h1.mb-4.text(style="color: #43adcf") Médico
                p.mb-2
                    strong Nombre y Apellido: 
                    | #{nombre} #{apellido}
                p.mb-2
                    strong Matricula: 
                    | #{matricula}
                p.mb-2
                    strong DNI: 
                    | #{dni}
                a.btn.btn-primary(href="/turno", style="background-color: #43adcf") Consultar Agenda

                
                //form(method="GET" action="/turno")
                    .mb-3
                        label.form-label Seleccionar fecha
                        input.form-control(type="date" name="fecha" required)

                    button.btn.btn-primary(style="background-color:#43adcf") Consultar agenda
